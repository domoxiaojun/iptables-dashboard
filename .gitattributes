# Project does not target Windows. All text files use LF on disk and in
# the repo — no per-extension carve-outs.
* text=auto eol=lf

# Binary assets — never normalize.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.zip   binary
*.tar.gz binary
